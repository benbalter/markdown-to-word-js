{
  "name": "markdown-to-word",
  "version": "1.0.0",
  "description": "Convert GitHub Flavored Markdown to Word documents in the browser",
  "type": "module",
  "engines": {
    "node": ">= 18.0.0"
  },
  "scripts": {
    "dev": "npx vite dev --host",
    "build": "npx tsc && npx vite build",
    "preview": "npx vite preview",
    "lint": "npx eslint . --ext .ts --fix",
    "format": "npx prettier --write .",
    "test": "echo 'No tests yet'"
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7",
    "@types/marked": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vite": "^5.4.11"
  },
  "dependencies": {
    "bootstrap": "^5.3.2",
    "clipboard": "^2.0.11",
    "docx": "^8.5.0",
    "file-saver": "^2.0.5",
    "marked": "^11.1.1"
  },
  "author": "Ben Balter <ben@balter.com>",
  "license": "MIT",
  "homepage": "https://benbalter.com/markdown-to-word-js/",
  "repository": {
    "type": "git",
    "url": "https://github.com/benbalter/markdown-to-word-js.git"
  },
  "keywords": [
    "markdown",
    "word",
    "docx",
    "converter",
    "github-flavored-markdown",
    "gfm"
  ]
}
